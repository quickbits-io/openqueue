{
  "name": "@openqueue/cli",
  "version": "0.1.4",
  "description": "OpenQueue CLI — scaffold, develop, build, and run OpenQueue workers. Bun-native.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/quickbits-io/openqueue/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quickbits-io/openqueue.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/quickbits-io/openqueue/issues"
  },
  "keywords": [
    "openqueue",
    "cli",
    "queue",
    "worker",
    "jobs",
    "bun"
  ],
  "bin": {
    "openqueue": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openqueue/core": "workspace:*",
    "@openqueue/worker": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/node": "^22.10.10",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
