{
  "name": "@openqueue/core",
  "version": "1.0.0",
  "description": "Core engine for OpenQueue — typed tasks, queues, schedules, flows, and Drizzle persistence over a pluggable world (delivery transport + durable store).",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/quickbits-io/openqueue/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quickbits-io/openqueue.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/quickbits-io/openqueue/issues"
  },
  "keywords": [
    "openqueue",
    "queue",
    "jobs",
    "background-jobs",
    "worker",
    "bun",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./control": {
      "types": "./dist/control.d.ts",
      "import": "./dist/control.js",
      "default": "./dist/control.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js",
      "default": "./dist/drizzle.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./world": {
      "types": "./dist/world.d.ts",
      "import": "./dist/world.js",
      "default": "./dist/world.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.11.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:transport": "vitest run src/transport",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.5.0",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
