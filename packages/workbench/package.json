{
  "name": "@openqueue/workbench",
  "version": "0.1.0",
  "description": "OpenQueue Workbench — an embeddable dashboard (queues, runs, schedules, flows, metrics, alerts) for BullMQ / OpenQueue, with Hono and Next.js adapters.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/quickbits-io/openqueue/tree/main/packages/workbench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quickbits-io/openqueue.git",
    "directory": "packages/workbench"
  },
  "bugs": {
    "url": "https://github.com/quickbits-io/openqueue/issues"
  },
  "keywords": [
    "openqueue",
    "workbench",
    "dashboard",
    "bullmq",
    "queue",
    "ui",
    "hono",
    "next"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "default": "./dist/hono.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "default": "./dist/next.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && vite build",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "dev:ui": "vite",
    "preview": "vite --host 0.0.0.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@openqueue/core": "workspace:*",
    "@scalar/hono-api-reference": "^0.11.3",
    "bullmq": "^5.71.1",
    "cron-parser": "^4.9.0",
    "hono": "^4.11.9",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.2.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "@types/bun": "^1.2.18",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.10.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "cronstrue": "^2.61.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.3",
    "recharts": "^2.15.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.7"
  }
}
