# Required
REDIS_URL=redis://localhost:6379

# API server port (Vite proxies /api → this port)
PORT=5679

# Static dir for production (built SPA output). Leave empty in dev — use Vite on :5678.
WORKBENCH_STATIC_DIR=

# CORS allowlist — comma-separated. Include your app URL so admins can deep-link.
WORKBENCH_CORS_ORIGIN=http://localhost:3000

# Auth — if unset, runs in OPEN mode (no auth). Set in production.
# Point at your identity provider's JWKS endpoint:
# WORKBENCH_AUTH_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# WORKBENCH_AUTH_AUDIENCE=
# WORKBENCH_AUTH_ISSUER=https://auth.example.com
