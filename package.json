{
  "name": "openqueue-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for OpenQueue — a Bun-native background job queue with a built-in workbench.",
  "license": "MIT",
  "homepage": "https://github.com/quickbits-io/openqueue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quickbits-io/openqueue.git"
  },
  "bugs": {
    "url": "https://github.com/quickbits-io/openqueue/issues"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.2.0"
  },
  "workspaces": [
    "packages/*",
    "site",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "release": "turbo run build --filter='./packages/*' && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
